# Optional dev-setup defaults.
# Copy this file to .env and adjust it for your machine.
#
#   cp .env.example .env
#   $EDITOR .env
#
# install.sh and menu.sh load .env automatically when it exists.

export DEV_SETUP_WORKSPACE_ROOT="$HOME/workspace"
export DEV_SETUP_ACCOUNT_DEFAULTS="personal,work"
export DEV_SETUP_ACCOUNT_COUNT="2"

# Advanced overrides. Most users can leave these commented.
# export DEV_SETUP_GIT_ACCOUNT_DIR="$HOME/.config/dev-setup/git/accounts"
# export DEV_SETUP_SSH_CONFIG="$HOME/.ssh/config"
