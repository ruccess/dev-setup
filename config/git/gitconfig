[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true

[merge]
	conflictstyle = zdiff3

[diff]
	colorMoved = default

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = false

[includeIf "gitdir:~/workspace/work/"]
	path = ~/.config/dev-setup/git/accounts/work.gitconfig

[includeIf "gitdir:~/workspace/company/"]
	path = ~/.config/dev-setup/git/accounts/work.gitconfig

[includeIf "gitdir:~/workspace/personal/"]
	path = ~/.config/dev-setup/git/accounts/personal.gitconfig

[alias]
	st = status --short --branch
	co = checkout
	br = branch
	cm = commit
	sw = switch
	last = log -1 HEAD --stat
	lg = log --graph --decorate --oneline --all
	uncommit = reset --soft HEAD~1
